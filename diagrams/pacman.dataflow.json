{
  "schema_version": 1,
  "diagram_type": "dataflow",
  "meta": {
    "title": "Pac-man AI Data Flow",
    "subtitle": "Map and user config to static search results and visualization",
    "output": "dataflow.html",
    "viewBox": [1080, 720]
  },
  "stages": [
    { "label": "Source" },
    { "label": "Parse" },
    { "label": "Search" },
    { "label": "Results" },
    { "label": "Render" }
  ],
  "nodes": [
    { "id": "mapfile", "type": "cloud", "label": "Demo Map", "sublabel": "tiny / small", "stage": 0, "row": 0, "tag": ".txt" },
    { "id": "config", "type": "frontend", "label": "User Config", "sublabel": "problem/algo/heuristic", "stage": 0, "row": 2, "tag": "UI" },
    { "id": "layout", "type": "backend", "label": "Layout Parser", "sublabel": "parse_layout()", "stage": 1, "row": 0, "tag": "builder" },
    { "id": "state", "type": "database", "label": "GameState", "sublabel": "immutable", "stage": 1, "row": 2, "tag": "dataclass" },
    { "id": "problem", "type": "backend", "label": "SearchProblem", "sublabel": "EatAll / PathTo", "stage": 2, "row": 0, "tag": "static" },
    { "id": "tree", "type": "backend", "label": "Search Tree", "sublabel": "created + expanded", "stage": 2, "row": 2, "tag": "g/h/f" },
    { "id": "hfn", "type": "security", "label": "Heuristic h(n)", "sublabel": "manhattan / food", "stage": 2, "row": 4, "tag": "admissible" },
    { "id": "result", "type": "database", "label": "Solve Result", "sublabel": "path/visited/tree", "stage": 3, "row": 0, "tag": "/solve" },
    { "id": "metrics", "type": "messagebus", "label": "SearchMetrics", "sublabel": "frontier/time/cost", "stage": 3, "row": 2, "tag": "counters" },
    { "id": "compare", "type": "database", "label": "Compare Result", "sublabel": "problem + results[]", "stage": 3, "row": 4, "tag": "/compare" },
    { "id": "canvas", "type": "frontend", "label": "Run View", "sublabel": "Canvas + SearchTree", "stage": 4, "row": 0, "tag": "visual" },
    { "id": "stats", "type": "frontend", "label": "Metrics View", "sublabel": "StatsPanel", "stage": 4, "row": 2, "tag": "UI" },
    { "id": "charts", "type": "frontend", "label": "Compare View", "sublabel": "table + charts", "stage": 4, "row": 4, "tag": "UI" }
  ],
  "flows": [
    { "from": "mapfile", "to": "layout", "label": "map text", "classification": "file I/O", "variant": "emphasis", "route": "straight" },
    { "from": "config", "to": "problem", "label": "problem + algorithm", "classification": "user choice", "variant": "default", "fromSide": "right", "toSide": "left", "via": [[222, 385], [222, 271], [400, 271], [400, 157]], "labelAt": [280, 220] },
    { "from": "layout", "to": "state", "label": "GameState", "classification": "parsed", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "straight", "labelAt": [315, 280] },
    { "from": "state", "to": "problem", "label": "initial state", "classification": "immutable", "variant": "emphasis", "fromSide": "right", "toSide": "left", "via": [[420, 385], [420, 157]], "labelAt": [438, 280] },
    { "from": "problem", "to": "tree", "label": "actions + result", "classification": "expand loop", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "straight", "labelAt": [530, 255] },
    { "from": "hfn", "to": "tree", "label": "h(state)", "classification": "cost estimate", "variant": "security", "fromSide": "top", "toSide": "bottom", "route": "straight", "labelAt": [530, 468] },
    { "from": "tree", "to": "result", "label": "path + visited + tree", "classification": "solve payload", "variant": "emphasis", "route": "straight", "labelAt": [638, 220] },
    { "from": "tree", "to": "metrics", "label": "counters", "classification": "algorithm data", "variant": "dashed", "fromSide": "bottom", "toSide": "top", "route": "straight", "labelAt": [638, 400] },
    { "from": "tree", "to": "compare", "label": "tree + optimal", "classification": "compare row", "variant": "default", "route": "straight", "labelAt": [638, 560] },
    { "from": "result", "to": "canvas", "label": "solve response", "classification": "render input", "variant": "emphasis", "route": "straight" },
    { "from": "metrics", "to": "stats", "label": "stats JSON", "classification": "display", "variant": "default", "route": "straight" },
    { "from": "compare", "to": "charts", "label": "problem + results[]", "classification": "no map/path/visited", "variant": "emphasis", "route": "straight" }
  ],
  "cards": [
    { "dot": "emerald", "title": "Solve Path", "items": ["Map → GameState → SearchProblem → tree/result", "/solve returns map, path, visited_order, tree, stats"] },
    { "dot": "rose", "title": "Compare Contract", "items": ["Top-level response: problem + results[]", "Rows contain algorithm, found, optimal, tree metadata, stats", "Compare omits map, path, visited_order"] },
    { "dot": "cyan", "title": "Metrics", "items": ["Expanded/generated nodes, max frontier, time, path length, cost", "No estimated-memory field"] }
  ]
}
