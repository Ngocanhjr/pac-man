{
  "schema_version": 1,
  "diagram_type": "workflow",
  "meta": {
    "title": "Pac-man AI Request Workflow",
    "subtitle": "Static solve, step playback, and algorithm comparison",
    "output": "workflow.html"
  },
  "lanes": [
    { "id": "user", "label": "User (Browser)" },
    { "id": "fe", "label": "React Frontend" },
    { "id": "api", "label": "FastAPI Backend" },
    { "id": "engine", "label": "Game + Search Engine" }
  ],
  "nodes": [
    { "id": "pick", "lane": "user", "col": 0, "type": "frontend", "label": "Choose config", "sublabel": "map/problem/algo/h" },
    { "id": "run", "lane": "user", "col": 2, "type": "frontend", "label": "Run action", "sublabel": "Run / Step / Compare" },
    { "id": "call", "lane": "fe", "col": 2, "type": "frontend", "label": "API Call", "sublabel": "/solve or /compare", "tag": "fetch" },
    { "id": "validate", "lane": "api", "col": 2, "type": "backend", "label": "Validate", "sublabel": "map + algorithm" },
    { "id": "guard", "lane": "api", "col": 3, "type": "security", "label": "Size Guard", "sublabel": "food > 25?", "width": 80 },
    { "id": "load", "lane": "engine", "col": 2, "type": "cloud", "label": "Load Layout", "sublabel": "tiny / small" },
    { "id": "solve", "lane": "engine", "col": 4, "type": "backend", "label": "Run Search", "sublabel": "BFS/DFS/UCS/Greedy/A*", "tag": "static" },
    { "id": "metrics", "lane": "engine", "col": 5, "type": "messagebus", "label": "Metrics", "sublabel": "frontier/time/cost" },
    { "id": "respond", "lane": "api", "col": 5, "type": "backend", "label": "JSON Response", "sublabel": "solve or compare" },
    { "id": "render", "lane": "fe", "col": 5, "type": "frontend", "label": "Render Result", "sublabel": "canvas/tree/charts", "tag": "UI" }
  ],
  "edges": [
    { "from": "pick", "to": "run", "variant": "emphasis" },
    { "from": "run", "to": "call", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "call", "to": "validate", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "validate", "to": "guard" },
    { "from": "guard", "to": "load", "label": "pass", "fromSide": "bottom", "toSide": "top", "route": "drop" },
    { "from": "load", "to": "solve", "variant": "emphasis" },
    { "from": "solve", "to": "metrics" },
    { "from": "metrics", "to": "respond", "label": "result", "fromSide": "top", "toSide": "bottom", "route": "drop" },
    { "from": "respond", "to": "render", "fromSide": "top", "toSide": "bottom", "route": "drop" }
  ],
  "cards": [
    { "dot": "cyan", "title": "/solve", "items": ["Returns map, actions, path, visited_order, tree, stats", "Run mode animates search and path", "Step mode rebuilds deterministic snapshots"] },
    { "dot": "emerald", "title": "/compare", "items": ["Top level: problem + results[]", "Rows: algorithm, found, optimal, tree metadata, stats", "No map, path, or visited_order in compare rows"] },
    { "dot": "rose", "title": "Guard", "items": ["eat_all rejects maps above 25 food", "tiny and small are valid demo maps"] }
  ]
}
